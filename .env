# ================================
# Server Configuration
# ================================
PORT=8080
NODE_ENV=development

# ================================
# MongoDB Connection
# ================================
MONGODB_URI=mongodb://127.0.0.1:27017/master_voice_platform

# যদি MongoDB Atlas ব্যবহার করো তাহলে নিচেরটা use করবে:
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/master_voice_platform?retryWrites=true&w=majority

# ================================
# JWT Authentication
# ================================
JWT_SECRET=labib_voice_platform_super_secret_key_2026_change_this_random_123456789
JWT_EXPIRES_IN=30d

# ================================
# Room Settings
# ================================
MAX_ROOM_USERS=16
MAX_AUDIO_BUFFER=800
HEARTBEAT_TIMEOUT=60000

# ================================
# File Upload Settings
# ================================
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=5242880

# ================================
# Default User Balance
# ================================
DEFAULT_COIN=1000
DEFAULT_DIAMOND=0

# ================================
# CORS - Frontend URL
# ================================
CLIENT_URL=http://localhost:8080

# ================================
# WebRTC / Agora - Optional
# ================================
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ================================
# Admin Account
# ================================
ADMIN_EMAIL=admin@voice.com
ADMIN_PASSWORD=admin123456
